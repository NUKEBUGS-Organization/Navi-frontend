# Backend API base URL (no trailing slash).
# Vite only exposes variables prefixed with VITE_ to the browser.
# VITE_API_URL=http://localhost:3000
#
# Docker/CapRover: pass as build arg so the bundle points at production API, e.g.
#   docker build --build-arg VITE_API_URL=https://api.yourdomain.com -t navi-web .
